<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FudAI" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.FudAI.Splash.Base" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/app_splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.FudAI</item>
    </style>

    <style name="Theme.FudAI.Splash" parent="Theme.FudAI.Splash.FudPink" />

    <style name="Theme.FudAI.Splash.FudPink" parent="Theme.FudAI.Splash.Base">
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
    </style>

    <style name="Theme.FudAI.Splash.Red" parent="Theme.FudAI.Splash.Base">
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_red</item>
    </style>

    <style name="Theme.FudAI.Splash.Orange" parent="Theme.FudAI.Splash.Base">
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_orange</item>
    </style>

    <style name="Theme.FudAI.Splash.Green" parent="Theme.FudAI.Splash.Base">
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_green</item>
    </style>

    <style name="Theme.FudAI.Splash.Mint" parent="Theme.FudAI.Splash.Base">
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_mint</item>
    </style>

    <style name="Theme.FudAI.Splash.Teal" parent="Theme.FudAI.Splash.Base">
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_teal</item>
    </style>

    <style name="Theme.FudAI.Splash.Blue" parent="Theme.FudAI.Splash.Base">
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_blue</item>
    </style>

    <style name="Theme.FudAI.Splash.Purple" parent="Theme.FudAI.Splash.Base">
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_purple</item>
    </style>
</resources>
