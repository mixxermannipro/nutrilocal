        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kamera + Kamera behält beide Aufnahmen, Seite an Seite zusammengefügt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cámara + Cámara conserva ambas capturas, unidas lado a lado."
