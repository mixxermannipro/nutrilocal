          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Новая вкладка «Тренировки» — 873 упражнения с фото, фильтрами по мышцам и оборудованию, поиском и страницами деталей."
          }
        },
        "zh-Hans" : {
