    "Recalculate also refreshes your optional nutrient targets like fiber, sugar, and sodium." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كما تعمل \"إعادة الحساب\" على تحديث أهداف العناصر الغذائية الاختيارية مثل الألياف والسكر والصوديوم."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yenidən hesablama həmçinin lif, şəkər və natrium kimi seçimli qida maddəsi hədəflərinizi də yeniləyir."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Neuberechnen werden auch deine optionalen Nährstoffziele wie Ballaststoffe, Zucker und Natrium aktualisiert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recalcular también actualiza tus objetivos de nutrientes opcionales, como fibra, azúcar y sodio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le recalcul actualise aussi vos cibles facultatives de nutriments comme les fibres, le sucre et le sodium."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "दोबारा गणना करने से आपके वैकल्पिक पोषक तत्व लक्ष्य जैसे फ़ाइबर, शुगर और सोडियम भी अपडेट हो जाते हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il ricalcolo aggiorna anche gli obiettivi opzionali per i nutrienti come fibre, zuccheri e sodio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "再計算では、食物繊維・糖質・ナトリウムなどの任意の栄養素目標も更新されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다시 계산 시 식이섬유, 당류, 나트륨 같은 선택 영양소 목표도 함께 갱신됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opnieuw berekenen werkt ook je optionele voedingsstofdoelen bij, zoals vezels, suiker en natrium."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przeliczanie odświeża również Twoje opcjonalne cele dotyczące składników odżywczych, takich jak błonnik, cukier i sód."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recalcular também atualiza suas metas opcionais de nutrientes, como fibras, açúcar e sódio."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recalcularea actualizează și obiectivele opționale de nutrienți, precum fibrele, zahărul și sodiul."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пересчёт также обновляет ваши дополнительные цели по нутриентам, такие как клетчатка, сахар и натрий."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "重新计算还会同步更新你可选的营养目标，如纤维、糖和钠。"
          }
        }
      }
    },
    "Recalculate Goals" : {
