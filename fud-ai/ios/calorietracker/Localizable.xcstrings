    "Food photos, voice transcripts, and typed meals are sent directly to your selected AI provider." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Essensfotos, Sprachtranskripte und getippte Mahlzeiten werden direkt an deinen gewählten KI-Anbieter gesendet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las fotos de comida, transcripciones de voz y comidas escritas se envían directamente a tu proveedor de IA seleccionado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les photos de repas, transcriptions vocales et repas saisis sont envoyés directement à votre fournisseur d'IA."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foto dei pasti, trascrizioni vocali e pasti digitati vengono inviati direttamente al provider IA selezionato."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotos de comida, transcrições de voz e refeições digitadas são enviadas diretamente ao provedor de IA selecionado."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voedselfoto's, spraaktranscripties en getypte maaltijden gaan rechtstreeks naar je gekozen AI-provider."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pozele cu mâncare, transcrierile vocale și mesele tastate sunt trimise direct furnizorului IA ales."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фото еды, голосовые расшифровки и введённые блюда отправляются напрямую выбранному ИИ-провайдеру."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zdjęcia jedzenia, transkrypcje głosowe i wpisane posiłki trafiają bezpośrednio do wybranego dostawcy AI."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "食事の写真、音声の書き起こし、入力した食事は選択したAIプロバイダーに直接送信されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "음식 사진, 음성 전사, 입력한 식사는 선택한 AI 제공업체로 직접 전송됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "食物照片、语音转写和输入的餐食会直接发送给你选择的 AI 服务商。"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُرسل صور الطعام والنصوص الصوتية والوجبات المكتوبة مباشرة إلى مزوّد الذكاء الاصطناعي الذي اخترته."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "खाने की फ़ोटो, वॉइस ट्रांसक्रिप्ट और टाइप किए गए मील सीधे आपके चुने हुए AI प्रोवाइडर को भेजे जाते हैं।"
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yemək şəkilləri, səs transkriptləri və yazılmış yeməklər birbaşa seçdiyiniz Sİ provayderinə göndərilir."
          }
        }
      }
    },
    "Foods will be copied to %@. The original entries stay unchanged." : {
      "comment" : "A footer that explains that the foods copied from a previous day will be added to the current day, but the original entries will remain unchanged. The argument is the string “today”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Produkty zostaną skopiowane do %@. Oryginalne wpisy pozostaną bez zmian."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Продукты будут скопированы в %@. Исходные записи останутся без изменений."
          }
        }
      }
    },
