    "Streak and summary notifications update automatically based on your logged food." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُحدَّث إشعارات السلسلة والملخصات تلقائيًا استنادًا إلى الطعام الذي قمت بتسجيله."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silsilə və xülasə bildirişləri qeyd etdiyiniz yeməklərə əsasən avtomatik yenilənir."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Serien- und Zusammenfassungs-Mitteilungen werden automatisch anhand deiner erfassten Lebensmittel aktualisiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Streak and summary notifications update automatically based on your logged food."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las notificaciones de racha y resumen se actualizan automáticamente según los alimentos que registres."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les notifications de série et de résumé se mettent à jour automatiquement selon vos aliments enregistrés."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "स्ट्रीक और सारांश सूचनाएँ आपके लॉग किए गए भोजन के आधार पर स्वचालित रूप से अपडेट होती हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le notifiche di serie e riepilogo si aggiornano automaticamente in base agli alimenti registrati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "連続記録と要約の通知は、記録した食事に基づいて自動的に更新されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "연속 기록 및 요약 알림은 기록한 음식에 따라 자동으로 업데이트됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Streak- en samenvattingsmeldingen worden automatisch bijgewerkt op basis van je geregistreerde voedsel."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powiadomienia o serii i podsumowaniu aktualizują się automatycznie na podstawie dodanych posiłków."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As notificações de sequência e resumo são atualizadas automaticamente com base nos seus alimentos registrados."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notificările de serie și rezumat se actualizează automat pe baza alimentelor înregistrate."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уведомления о серии и сводках обновляются автоматически на основе ваших записей о еде."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "连续记录和摘要通知会根据你记录的食物自动更新。"
