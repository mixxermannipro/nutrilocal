    "Body fat history: review and delete individual entries, just like weight." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سجل دهون الجسم: راجع واحذف الإدخالات الفردية تمامًا كما في الوزن."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bədən yağı tarixçəsi: çəki kimi ayrı-ayrı qeydlərə baxın və silin."
