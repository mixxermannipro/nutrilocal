    "Get notified when a new version is available. Tap the notification to open the App Store." : {
      "comment" : "A footer for the notification settings.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "احصل على إشعار عند توفر إصدار جديد. اضغط على الإشعار لفتح App Store."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yeni versiya mövcud olduqda bildiriş alın. App Store-u açmaq üçün bildirişə toxunun."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erhalte eine Mitteilung, wenn eine neue Version verfügbar ist. Tippe auf die Mitteilung, um den App Store zu öffnen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recibe una notificación cuando haya una nueva versión disponible. Toca la notificación para abrir el App Store."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recevez une notification quand une nouvelle version est disponible. Touchez la notification pour ouvrir l'App Store."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "नया वर्ज़न उपलब्ध होने पर सूचना पाएँ। App Store खोलने के लिए सूचना पर टैप करें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ricevi una notifica quando è disponibile una nuova versione. Tocca la notifica per aprire l'App Store."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しいバージョンが利用可能になったら通知を受け取れます。通知をタップするとApp Storeが開きます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "새 버전이 나오면 알림을 받으세요. 알림을 탭하면 App Store가 열립니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ontvang een melding wanneer er een nieuwe versie beschikbaar is. Tik op de melding om de App Store te openen."
          }
        },
        "pl" : {
          "stringUnit" : {
