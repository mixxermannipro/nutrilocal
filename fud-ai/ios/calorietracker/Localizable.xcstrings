    "Notifications are disabled in system settings. Tap to open Settings." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الإشعارات معطلة في إعدادات النظام. اضغط لفتح الإعدادات."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bildirişlər sistem parametrlərində söndürülüb. Parametrləri açmaq üçün toxunun."
          }
        },
        "de" : {
          "stringUnit" : {
