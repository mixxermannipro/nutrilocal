      "isCommentAutoGenerated" : true,
      "localizations" : {
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wszystkie cztery przypomnienia są inteligentne — nie uruchamiają się w dniach, w których masz już wpis. Domyślnie tkanka tłuszczowa jest wyłączona, bo większość użytkowników nie mierzy jej codziennie."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Все четыре напоминания умные — они не срабатывают в дни, когда вы уже внесли данные. Напоминание о жире отключено по умолчанию, так как большинство пользователей не измеряет его каждый день."
          }
        }
      }
    },
