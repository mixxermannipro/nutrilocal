    "Adaptive Goals and Energy Burn left Experimental and are on by default for new installs." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تخرّجت ميزتا الأهداف التكيفية وحرق الطاقة من المرحلة التجريبية وأصبحتا مفعّلتين افتراضيًا للتثبيتات الجديدة."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adaptiv Məqsədlər və Enerji Sərfi eksperimental mərhələdən çıxdı və yeni quraşdırmalarda defolt olaraq aktivdir."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adaptive Ziele und Energieverbrauch sind nicht mehr experimentell und bei Neuinstallationen standardmäßig aktiv."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Objetivos adaptativos y Quema de energía dejan de ser experimentales y vienen activados por defecto en instalaciones nuevas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Objectifs adaptatifs et Énergie brûlée sortent de l'expérimental et sont activés par défaut pour les nouvelles installations."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adaptive Goals और Energy Burn अब प्रयोगात्मक नहीं हैं और नए इंस्टॉल पर डिफ़ॉल्ट रूप से चालू हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obiettivi adattivi ed Energia bruciata escono dalla fase sperimentale e sono attivi di default sulle nuove installazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アダプティブ目標とエネルギー消費が実験的機能を卒業し、新規インストールではデフォルトでオンに。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "적응형 목표와 에너지 소모가 실험 단계를 졸업하고 새 설치에서 기본으로 켜집니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adaptieve doelen en Energieverbruik zijn niet langer experimenteel en staan standaard aan bij nieuwe installaties."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cele adaptacyjne i Spalanie energii wyszły z fazy eksperymentalnej i są domyślnie włączone przy nowych instalacjach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Metas adaptativas e Queima de energia saíram da fase experimental e vêm ativadas por padrão em novas instalações."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obiectivele adaptive și Energia consumată au ieșit din faza experimentală și sunt activate implicit la instalările noi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Адаптивные цели» и «Расход энергии» вышли из экспериментального статуса и включены по умолчанию для новых установок."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自适应目标和能量消耗已结束实验阶段，新安装默认开启。"
          }
        }
      }
    },
