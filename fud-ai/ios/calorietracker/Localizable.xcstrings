          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваша поддержка сохраняет Fud AI бесплатным для всех."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twoje wsparcie utrzymuje Fud AI darmowym dla wszystkich."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたのサポートがFud AIをみんなの無料アプリに保ちます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여러분의 후원이 Fud AI를 모두에게 무료로 유지해 줍니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的支持让 Fud AI 对所有人保持免费。"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "دعمك يُبقي Fud AI مجانيًا للجميع."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपका सहयोग Fud AI को सबके लिए मुफ़्त रखता है।"
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dəstəyiniz Fud AI-ni hamı üçün pulsuz saxlayır."
          }
        }
      }
    },
    "Reinstalled or switched phones? Your food log, weight, and body fat now restore automatically from Apple Health." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أعدت التثبيت أو غيّرت هاتفك؟ يُستعاد الآن سجل طعامك ووزنك ودهون جسمك تلقائيًا من Apple Health."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yenidən quraşdırmısınız və ya telefonu dəyişmisiniz? Yemək jurnalınız, çəkiniz və bədən yağınız indi Apple Health-dən avtomatik bərpa olunur."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neu installiert oder neues iPhone? Ernährungstagebuch, Gewicht und Körperfett werden jetzt automatisch aus Apple Health wiederhergestellt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Reinstalaste o cambiaste de teléfono? Tu registro de comidas, peso y grasa corporal ahora se restauran automáticamente desde Apple Health."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réinstallation ou nouveau téléphone ? Ton journal alimentaire, ton poids et ta masse grasse se restaurent désormais automatiquement depuis Apple Health."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "दोबारा इंस्टॉल किया या फ़ोन बदला? आपका फ़ूड लॉग, वज़न और बॉडी फ़ैट अब Apple Health से अपने आप बहाल हो जाते हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hai reinstallato o cambiato telefono? Diario alimentare, peso e grasso corporeo ora si ripristinano automaticamente da Apple Health."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "再インストールや機種変更をしても、食事記録・体重・体脂肪がApple Healthから自動的に復元されるようになりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "재설치했거나 휴대폰을 바꿨나요? 이제 음식 기록, 체중, 체지방이 Apple Health에서 자동으로 복원됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opnieuw geïnstalleerd of een nieuwe telefoon? Je voedingslogboek, gewicht en vetpercentage worden nu automatisch hersteld uit Apple Health."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ponowna instalacja lub nowy telefon? Dziennik posiłków, waga i tkanka tłuszczowa są teraz automatycznie przywracane z Apple Health."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reinstalou ou trocou de celular? Seu diário alimentar, peso e gordura corporal agora são restaurados automaticamente do Apple Health."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ai reinstalat sau ai schimbat telefonul? Jurnalul alimentar, greutatea și grăsimea corporală se restaurează acum automat din Apple Health."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Переустановили приложение или сменили телефон? Дневник питания, вес и процент жира теперь автоматически восстанавливаются из Apple Health."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "重新安装或更换手机后，你的饮食记录、体重和体脂现在会从 Apple Health 自动恢复。"
          }
        }
      }
    },
    "Share any meal as a link that opens straight in Fud AI." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "شارك أي وجبة كرابط يفتح مباشرة في Fud AI."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İstənilən yeməyi birbaşa Fud AI-da açılan link kimi paylaşın."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Teile jede Mahlzeit als Link, der direkt in Fud AI öffnet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comparte cualquier comida como un enlace que se abre directamente en Fud AI."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Partage n'importe quel repas via un lien qui s'ouvre directement dans Fud AI."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी भी भोजन को लिंक के रूप में साझा करें जो सीधे Fud AI में खुलता है।"
          }
