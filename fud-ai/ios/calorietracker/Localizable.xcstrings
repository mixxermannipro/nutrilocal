    "New Workouts tab — browse 873 exercises with photos, muscle and equipment filters, search, and detail pages." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "علامة تبويب تمارين جديدة — تصفّح 873 تمرينًا مع الصور وفلاتر العضلات والمعدات والبحث وصفحات التفاصيل."
          }
        },
        "az" : {
          "stringUnit" : {
