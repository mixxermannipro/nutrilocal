        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuova scheda Allenamenti — sfoglia 873 esercizi con foto, filtri per muscolo e attrezzatura, ricerca e pagine di dettaglio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しいワークアウトタブ — 写真、筋肉・器具フィルター、検索、詳細ページ付きの873種目をブラウズ。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "새로운 운동 탭 — 사진, 근육·장비 필터, 검색, 상세 페이지와 함께 873가지 운동을 둘러보세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nieuw Workouts-tabblad — blader door 873 oefeningen met foto's, spier- en materiaalfilters, zoeken en detailpagina's."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nowa karta Treningi — przeglądaj 873 ćwiczenia ze zdjęciami, filtrami mięśni i sprzętu, wyszukiwaniem i stronami szczegółów."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
