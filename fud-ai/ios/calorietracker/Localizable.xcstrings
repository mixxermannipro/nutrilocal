    "Your food log, weight history, body-fat history, and BYOK API keys stay on this device." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Ernährungstagebuch, Gewichtsverlauf, Körperfettverlauf und BYOK-API-Schlüssel bleiben auf diesem Gerät."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu registro de comidas, historial de peso, historial de grasa corporal y claves API BYOK permanecen en este dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre journal alimentaire, l'historique de poids, de masse grasse et vos clés API BYOK restent sur cet appareil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il diario alimentare, lo storico di peso e massa grassa e le chiavi API BYOK restano su questo dispositivo."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu diário alimentar, histórico de peso, histórico de gordura corporal e chaves de API BYOK ficam neste aparelho."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je voedingslog, gewichts- en vetpercentagegeschiedenis en BYOK-API-sleutels blijven op dit apparaat."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jurnalul alimentar, istoricul greutății, al grăsimii corporale și cheile API BYOK rămân pe acest dispozitiv."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваш дневник питания, история веса и жира, а также BYOK API-ключи остаются на этом устройстве."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twój dziennik posiłków, historia wagi i tkanki tłuszczowej oraz klucze API BYOK pozostają na tym urządzeniu."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "食事記録、体重・体脂肪の履歴、BYOKのAPIキーはこの端末内に保存されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "음식 기록, 체중·체지방 기록, BYOK API 키는 이 기기에만 저장됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的饮食记录、体重和体脂历史以及 BYOK API 密钥都保存在本设备上。"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يبقى سجل طعامك وتاريخ وزنك ودهون جسمك ومفاتيح BYOK API على هذا الجهاز."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपका फ़ूड लॉग, वज़न हिस्ट्री, बॉडी-फैट हिस्ट्री और BYOK API कीज़ इसी डिवाइस पर रहती हैं।"
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yemək qeydləriniz, çəki və bədən yağı tarixçəniz və BYOK API açarlarınız bu cihazda qalır."
          }
        }
      }
    },
    "Your plan auto-adjusts weekly as you log — turn off Adaptive Goals in Settings to keep it fixed." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Plan passt sich wöchentlich an, während du loggst — deaktiviere Adaptive Goals in den Einstellungen, um ihn fest zu lassen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu plan se ajusta automáticamente cada semana según lo que registras — desactiva Adaptive Goals en Ajustes para mantenerlo fijo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre plan s'ajuste automatiquement chaque semaine selon vos repas — désactivez Adaptive Goals dans Réglages pour le garder fixe."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo piano si adatta automaticamente ogni settimana in base ai log — disattiva Adaptive Goals nelle Impostazioni per mantenerlo fisso."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu plano se ajusta automaticamente toda semana conforme você registra — desative o Adaptive Goals em Ajustes para mantê-lo fixo."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je plan past zich wekelijks aan op basis van je logs — zet Adaptive Goals uit in Instellingen om het vast te houden."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Planul tău se ajustează automat săptămânal pe măsură ce înregistrezi — dezactivează Adaptive Goals din Setări pentru a-l păstra fix."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваш план автоматически корректируется каждую неделю по мере записей — отключите Адаптивные цели в настройках, чтобы он оставался неизменным."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twój plan dostosowuje się co tydzień na podstawie wpisów — wyłącz Cele adaptacyjne w Ustawieniach, aby pozostał stały."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プランは記録に合わせて週1回自動調整されます。固定したい場合は設定でAdaptive Goalsをオフにしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "플랜은 기록에 따라 매주 자동 조정됩니다 — 고정하려면 설정에서 Adaptive Goals를 끄세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的计划会根据记录每周自动调整 — 想保持不变，可在设置中关闭 Adaptive Goals。"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتعدّل خطتك تلقائيًا كل أسبوع حسب تسجيلاتك — أوقف Adaptive Goals من الإعدادات لإبقائها ثابتة."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपका प्लान आपकी लॉगिंग के अनुसार हर हफ़्ते अपने आप एडजस्ट होता है — इसे स्थिर रखने के लिए सेटिंग्स में Adaptive Goals बंद करें।"
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Planınız qeydlərinizə əsasən hər həftə avtomatik tənzimlənir — sabit saxlamaq üçün Parametrlərdə Adaptive Goals-u söndürün."
          }
        }
      }
    },
    "Your support keeps Fud AI free for everyone." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Unterstützung hält Fud AI für alle kostenlos."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu apoyo mantiene Fud AI gratis para todos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre soutien garde Fud AI gratuit pour tous."
          }
        },
        "it" : {
          "stringUnit" : {
