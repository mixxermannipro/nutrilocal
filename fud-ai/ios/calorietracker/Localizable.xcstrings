        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Körperfett-Verlauf: einzelne Einträge ansehen und löschen, genau wie beim Gewicht."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
