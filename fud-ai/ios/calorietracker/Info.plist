<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>AppGroupIdentifier</key>
	<string>$(APP_GROUP_IDENTIFIER)</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Connect to an Ollama server running on your local network.</string>
	<key>CFBundleDisplayName</key>
	<string>$(APP_DISPLAY_NAME)</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Read your weight, height, body composition, nutrition, and Fud AI workout calories to keep your history in sync.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Write, update, or remove your nutrition, body measurements, and calculated workout calories when you change your logs.</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.apoorvdarshan.calorietracker</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>fudai</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
